<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- TOP HUD -->
    <LinearLayout android:id="@+id/hud_top"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp"
        android:background="#1a1a2e"
        app:layout_constraintTop_toTopOf="parent">
        <TextView android:id="@+id/tv_points"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🪙 0" android:textColor="#FFD700"
            android:textSize="18sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:orientation="vertical"
            android:gravity="end">
            <TextView android:id="@+id/tv_scan_count"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚡ 0/15 Rewards" android:textColor="#6C63FF"
                android:textSize="13sp" android:textStyle="bold"/>
            <ProgressBar android:id="@+id/progress_scans"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="120dp" android:layout_height="8dp"
                android:max="15" android:progress="0"
                android:progressTint="#6C63FF"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CAMERA -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent" android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/hud_top"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- STATUS -->
    <TextView android:id="@+id/tv_status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#CC000000" android:textColor="#FFFFFF"
        android:textSize="14sp" android:padding="12dp"
        android:gravity="center" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hud_top"/>

    <!-- COOLDOWN -->
    <TextView android:id="@+id/tv_cooldown"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:background="#6C63FF" android:textColor="#FFFFFF"
        android:textSize="13sp" android:padding="8dp"
        android:layout_margin="16dp" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
